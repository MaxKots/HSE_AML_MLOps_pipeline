APP_ENV=local
APP_NAME=aml-pipeline

DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATA_REFERENCE_DIR=data/reference
ARTIFACTS_DIR=artifacts

BASE_DATASET_PATH=data/raw/Base.csv
DRIFT_DATASET_PATH_1=data/raw/Variant I.csv
DRIFT_DATASET_PATH_2=data/raw/Variant II.csv

TARGET_COLUMN=fraud_bool
RANDOM_SEED=42

MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT_NAME=aml_detection

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=aml
POSTGRES_USER=aml_user
POSTGRES_PASSWORD=aml_password

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=mlflow

API_HOST=0.0.0.0
API_PORT=8000
DASHBOARD_API_URL=http://localhost:8000
